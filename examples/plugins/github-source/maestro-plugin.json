{
  "name": "github-source",
  "version": "0.1.0",
  "description": "Pull tasks from GitHub Issues, write results back",
  "author": "Denislav Prinov",
  "homepage": "https://github.com/denislavprinov/maestro-plugins",
  "license": "MIT",
  "engines": { "maestro-api": ">=1 <2" },
  "taskSources": [
    {
      "id": "github",
      "displayName": "GitHub Issues",
      "module": "./connector/index.mjs",
      "configSchema": [
        {
          "key": "token",
          "type": "text",
          "secret": true,
          "required": true,
          "label": "GitHub token",
          "help": "Fine-grained PAT (Issues R/W + Metadata R), `gh auth token`, or {\"$env\":\"GH_TOKEN\"}"
        },
        {
          "key": "closeOnComplete",
          "type": "select",
          "label": "Close issue on completion",
          "default": "no",
          "options": ["yes", "no"],
          "help": "yes = close the issue (state_reason: completed) when a pipeline finishes successfully"
        }
      ],
      "inputs": [
        { "key": "repo", "type": "remote-select", "label": "Repository", "optionsFrom": "listRepos" },
        { "key": "filter", "type": "text", "label": "Filter", "default": "assignee:@me state:open" },
        { "key": "task", "type": "task-browser", "label": "Issue" }
      ]
    }
  ]
}
